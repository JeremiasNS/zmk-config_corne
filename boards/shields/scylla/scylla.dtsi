 * в”њв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”¤   в”њв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”¤
 * в”‚ R1C0 в”‚ R1C1 в”‚ R1C2 в”‚ R1C3 в”‚ R1C4 в”‚ R1C5 в”‚   в”‚ R1C6 в”‚ R1C7 в”‚ R1C8 в”‚ R1C9 в”‚R1C10 в”‚R1C11 в”‚
 * в”њв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”¤   в”њв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”¤
 * в”‚ R2C0 в”‚ R2C1 в”‚ R2C2 в”‚ R2C3 в”‚ R2C4 в”‚ R2C5 в”‚   в”‚ R2C6 в”‚ R2C7 в”‚ R2C8 в”‚ R2C9 в”‚R2C10 в”‚R2C11 в”‚
 * в”њв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”¤   в”њв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”¤
 * в”‚ R3C0 в”‚ R3C1 в”‚ R3C2 в”‚ R3C3 в”‚ R3C4 в”‚ R3C5 в”‚   в”‚ R3C6 в”‚ R3C7 в”‚ R3C8 в”‚ R3C9 в”‚R3C10 в”‚R3C11 в”‚
 * в•°в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”ґв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”ґв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”¤   в”њв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”ґв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”ґв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•Ї
 *                      в”‚ R4C3 в”‚ R4C4 в”‚ R4C5 в”‚   в”‚ R4C6 в”‚ R4C7 в”‚ R4C8 в”‚
 *                      в•°в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•Ї   в•°в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”јв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•Їв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•Ї
 *                             в”‚ R5C4 в”‚ R5C5 в”‚   в”‚ R5C6 в”‚ R5C7 в”‚
 *                             в•°в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”ґв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•Ї   в•°в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”ґв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•Ї
 *
 * Diodos: anodo в†’ coluna, catodo в†’ linha  в€ґ  col2row
 *
 * Linhas вЂ” entradas (PULL_DOWN), compartilhadas esq e dir:
 *   R0 в†’ pro_micro 2  (P0.17)
 *   R1 в†’ pro_micro 3  (P0.20)
 *   R2 в†’ pro_micro 4  (P0.22)
 *   R3 в†’ pro_micro 5  (P0.24)
 *   R4 в†’ pro_micro 6  (P1.00)  thumb superior
 *   R5 в†’ pro_micro 7  (P0.11)  thumb inferior
 *
 * Colunas вЂ” saГ­das (sem pull), definidas nos overlays:
 *   C0/C6  в†’ pro_micro 8  (P1.04)
 *   C1/C7  в†’ pro_micro 9  (P1.06)
 *   C2/C8  в†’ pro_micro 21 (P0.31)
 *   C3/C9  в†’ pro_micro 20 (P0.29)
 *   C4/C10 в†’ pro_micro 19 (P0.02)
 *   C5/C11 в†’ pro_micro 18 (P1.15)
 */

#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix_transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <6>;
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)  RC(0,5)   RC(0,6)  RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)  RC(1,5)   RC(1,6)  RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)  RC(2,5)   RC(2,6)  RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4)  RC(3,5)   RC(3,6)  RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11)
                         RC(4,3) RC(4,4)  RC(4,5)   RC(4,6)  RC(4,7) RC(4,8)
                                 RC(5,4)  RC(5,5)   RC(5,6)  RC(5,7)
        >;
    };

    encoder: encoder_0 {
        compatible = "alps,ec11";
        a-gpios = <&pro_micro 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&pro_micro 14 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <80>;
        status = "disabled";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&encoder>;
        triggers-per-rotation = <20>;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        wakeup-source;

        row-gpios
            = <&pro_micro 2  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* R0 */
            , <&pro_micro 3  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* R1 */
            , <&pro_micro 4  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* R2 */
            , <&pro_micro 5  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* R3 */
            , <&pro_micro 6  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* R4 thumb */
            , <&pro_micro 7  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* R5 thumb */
            ;
    };
};
